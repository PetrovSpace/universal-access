# config.env.example — параметры universal-access.
# Скопируйте в config.env и при необходимости переопределите значения.
# Все значения ниже — дефолты; любая строка опциональна.

# --- Общее -------------------------------------------------------------------
# Публичный IP сервера. Пусто = автоопределение (ipify/ifconfig.me/ipinfo/icanhazip).
#PUBLIC_IP=""

# --- Клиенты -----------------------------------------------------------------
# Список пользователей для VLESS/Reality и MTProto. Добавление = дописать в массив и перезапустить install.sh.
CLIENTS=("andrey" "wife")

# Список устройств AmneziaWG. На каждое — отдельный .conf (один conf = одно устройство).
AWG_PEERS=("mac" "keenetic" "windows")

# --- AmneziaWG (UDP, основной канал) -----------------------------------------
# UDP-порт AmneziaWG (при занятости автоматически берётся следующий свободный).
AWG_PORT=51820
# Подсеть туннеля AmneziaWG.
AWG_SUBNET="10.13.13.0/24"
# MTU интерфейса.
AWG_MTU=1420
# Параметры обфускации AmneziaWG 2.0 (дефолты Amnezia).
AWG_JC=4        # число junk-пакетов
AWG_JMIN=40     # мин. размер junk-пакета
AWG_JMAX=70     # макс. размер junk-пакета
AWG_S1=0        # размер junk-данных в init-пакете
AWG_S2=0        # размер junk-данных в response-пакете
AWG_H1=1        # тип заголовка (магия) 1
AWG_H2=2        # тип заголовка (магия) 2
AWG_H3=3        # тип заголовка (магия) 3
AWG_H4=4        # тип заголовка (магия) 4

# --- VLESS + Reality (TCP) ---------------------------------------------------
# Порт blacklist-режима (для Happ).
REALITY_PORT_BLACKLIST=443
# Порт whitelist-режима (мобильные операторы РФ / TSPU).
REALITY_PORT_WHITELIST=8443
# SNI для blacklist: иностранный нейтральный домен с TLS 1.3 + HTTP/2. Первый валидный выигрывает.
REALITY_SNI_BLACKLIST=("www.microsoft.com" "www.cloudflare.com" "www.amazon.com")
# SNI для whitelist: РАЗРЕШЁННЫЙ российский ресурс (иначе TSPU рвёт handshake). Первый валидный выигрывает.
REALITY_SNI_WHITELIST=("gosuslugi.ru" "www.gosuslugi.ru" "www.sberbank.ru")

# --- MTProto (Telegram, mtg fake-TLS) ----------------------------------------
# Порт MTProto (8888, чтобы не конфликтовать с whitelist 8443; при занятости автобамп).
MTPROTO_PORT=8888
# Домен для маскировки fake-TLS.
MTPROTO_MASK_DOMAIN="www.cloudflare.com"

# --- Hysteria2 (опционально) -------------------------------------------------
# Включить Hysteria2 (по умолчанию выключен).
ENABLE_HYSTERIA2=false
# UDP-порт Hysteria2.
HYSTERIA2_PORT=36712
