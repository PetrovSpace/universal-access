# Параметры РФ-релея (план Б). Скопируй в ../local/relay.env и впиши реальные значения.
# local/relay.env в .gitignore — секреты в публичный репозиторий не попадут.
# Запуск:  cat local/relay.env universal-access/tools/install-relay.sh | ssh ru 'bash -s'

# --- Зарубежный выходной сервер (куда релей переправляет трафик) ---
FOREIGN_IP=1.2.3.4          # IP зарубежного сервера (egress)
FOREIGN_PORT=2053           # gRPC-порт зарубежного сервера
FOREIGN_UUID=               # UUID клиента на зарубежном (state: xray_uuid_<клиент>)
FOREIGN_PUBKEY=             # Reality public key зарубежного (state: xray_reality_public)
FOREIGN_SHORTID=            # shortId gRPC-инбаунда зарубежного (state: xray_shortid_grpc)

# --- Релей (точка входа на промежуточном РФ-сервере) ---
RELAY_PORT=443              # порт входа на релее
RELAY_UUID=                 # UUID клиента, вписанный в твой vless-relay-planB.json
RELAY_PRIVKEY=              # Reality private key релея
RELAY_SHORTID=              # shortId релея

# --- Общее (можно не трогать) ---
SNI=www.microsoft.com
GRPC_SERVICE=grpc
